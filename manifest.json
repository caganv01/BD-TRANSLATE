{
  "manifest_version": 3,
  "name": "BD-Translate",
  "version": "1.0",
  "description": "İngilizce kelimeleri çevir ve kaydet",
  "permissions": [
  "storage",
  "identity"
],
  "host_permissions": [
  "https://script.google.com/*",
  "https://script.googleusercontent.com/*"
],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
  {
    "matches": ["<all_urls>"],
    "js": ["config.js", "content.js"]
  }
]
}